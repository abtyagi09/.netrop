{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Azure": {
    "AI": {
      "FoundryProjectEndpoint": "https://your-project.api.azureml.ms",
      "AgentName": "my-agent",
      "Model": "gpt-5-mini"
    }
  },
  "AgentCaching": {
    "Enabled": true,
    "RefreshIntervalMinutes": 30
  }
}
