# Example environment variables
# Copy this to .env and fill in your values

# Azure AI Foundry Configuration
FOUNDRY_ENDPOINT=https://aifoundryprojectdemoresource.services.ai.azure.com/api/projects/aifoundryprojectagentsdemo
AGENT_NAME=Agent319

# Agent Caching Configuration
AGENT_CACHING_ENABLED=true
AGENT_CACHING_REFRESH_MINUTES=30

